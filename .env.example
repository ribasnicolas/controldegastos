# ─── Base de datos (Supabase) ─────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string → URI
# Usar el connection pooler (puerto 6543) para runtime y el directo (5432) para migraciones.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── NextAuth ───────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
AUTH_SECRET="tu-secreto-aqui"

# ─── Cron de gastos/ingresos fijos (Vercel Cron) ────────────────────────────
# Generar con: openssl rand -base64 32
CRON_SECRET="tu-secreto-de-cron-aqui"

# ─── Seed inicial (opcional, solo para prisma/seed.ts) ──────────────────────
ADMIN_NAME="Nicolas"
ADMIN_EMAIL="ribasnicolas@gmail.com"
ADMIN_PASSWORD="cambiar-esta-contraseña"
