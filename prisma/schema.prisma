generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

enum CategoryType {
  EXPENSE
  INCOME
}

enum Currency {
  ARS
  USD
}

enum SavingType {
  DEPOSIT
  WITHDRAWAL
}

enum PaymentMethod {
  CASH
  TRANSFER
  CREDIT_CARD
}

// ─── Hogar (grupo opcional para ver un dashboard combinado) ──────────────────

model Household {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique @default(cuid())
  createdAt  DateTime @default(now())
  users      User[]
}

// ─── Usuario ───────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  role        Role     @default(USER)
  active      Boolean  @default(true)
  householdId String?
  household   Household? @relation(fields: [householdId], references: [id])
  actualBalance Decimal? @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expenses          Expense[]
  incomes           Income[]
  budgets           Budget[]
  recurringExpenses RecurringExpense[]
  recurringIncomes  RecurringIncome[]
  savingEntries     SavingEntry[]
  debts             Debt[]
}

// ─── Categorías de gasto e ingreso (gestionadas desde el módulo admin) ────

model Category {
  id        String       @id @default(cuid())
  name      String
  icon      String?
  color     String?
  type      CategoryType @default(EXPENSE)
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())

  expenses          Expense[]
  incomes           Income[]
  budgets           Budget[]
  recurringExpenses RecurringExpense[]
  recurringIncomes  RecurringIncome[]

  @@unique([name, type])
}

// ─── Gastos ──────────────────────────────────────────────────────────────

model Expense {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId         String
  category           Category @relation(fields: [categoryId], references: [id])
  amount             Decimal       @db.Decimal(12, 2)
  description        String?
  icon               String?
  paymentMethod      PaymentMethod @default(TRANSFER)
  date               DateTime      @default(now())
  createdAt          DateTime      @default(now())
  sourceRecurringId  String?

  @@index([userId, date])
}

// ─── Ingresos ────────────────────────────────────────────────────────────

model Income {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId         String
  category           Category @relation(fields: [categoryId], references: [id])
  amount             Decimal  @db.Decimal(12, 2)
  description        String?
  icon               String?
  date               DateTime @default(now())
  createdAt          DateTime @default(now())
  sourceRecurringId  String?

  @@index([userId, date])
}

// ─── Presupuestos por categoría y mes ───────────────────────────────────

model Budget {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  amount     Decimal  @db.Decimal(12, 2)
  month      Int
  year       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, categoryId, month, year])
}

// ─── Gastos fijos recurrentes (requieren confirmación manual de pago) ────

model RecurringExpense {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId          String
  category            Category @relation(fields: [categoryId], references: [id])
  amount              Decimal  @db.Decimal(12, 2)
  description         String?
  dayOfMonth          Int
  active              Boolean  @default(true)
  lastGeneratedMonth  Int?
  lastGeneratedYear   Int?
  createdAt           DateTime @default(now())
}

// ─── Ingresos fijos recurrentes ──────────────────────────────────────────

model RecurringIncome {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId          String
  category            Category @relation(fields: [categoryId], references: [id])
  amount              Decimal  @db.Decimal(12, 2)
  description         String?
  dayOfMonth          Int
  active              Boolean  @default(true)
  lastGeneratedMonth  Int?
  lastGeneratedYear   Int?
  createdAt           DateTime @default(now())
}

// ─── Ahorros (en pesos o dólares) ─────────────────────────────────────────

model SavingEntry {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Decimal    @db.Decimal(12, 2)
  currency    Currency
  type        SavingType @default(DEPOSIT)
  description String?
  date        DateTime   @default(now())
  createdAt   DateTime   @default(now())

  @@index([userId, date])
}

// ─── Deudas (plata que te deben) ──────────────────────────────────────────

model Debt {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  personName      String
  amount          Decimal  @db.Decimal(12, 2)
  description     String?
  settled         Boolean  @default(false)
  settledIncomeId String?
  date            DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([userId, settled])
}
